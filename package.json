{
  "name": "tire-reseller",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "node scripts/db-provider.mjs && prisma generate && next build",
    "start": "next start -p 3000",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "setup": "prisma db push && node prisma/seed.js",
    "test": "node --test",
    "audit:ci": "npm audit --omit=dev --audit-level=high"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "jose": "5.9.6",
    "next": "^15.5.19",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "17.4.0"
  },
  "devDependencies": {
    "autoprefixer": "10.4.20",
    "postcss": "^8.5.15",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.15"
  }
}
