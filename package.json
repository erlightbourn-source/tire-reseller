{
  "name": "tire-reseller",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "node scripts/db-provider.mjs && prisma generate && next build",
    "start": "next start -p 3000",
    "postinstall": "node scripts/db-provider.mjs && prisma generate",
    "db:push": "node scripts/db-provider.mjs && prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "backfill": "node prisma/backfill.mjs",
    "demo:css": "tailwindcss -c docs/_tw/tailwind.config.cjs -i docs/_tw/input.css -o docs/tw.css --minify",
    "setup": "node scripts/db-provider.mjs && prisma db push && node prisma/seed.js",
    "test": "node --test",
    "test:e2e": "node --test e2e/flows.mjs",
    "audit:ci": "npm audit --omit=dev --audit-level=high"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "^15.5.19",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^22.2.2"
  },
  "devDependencies": {
    "autoprefixer": "10.4.20",
    "postcss": "^8.5.15",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.15"
  }
}
