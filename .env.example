# ─────────────────────────────────────────────────────────────────────────────
# TireTrader — Environment configuration
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Local SQLite database (no setup required)
DATABASE_URL="file:./dev.db"

# Secret used to sign login session cookies. Use any long random string.
# Generate one with:  openssl rand -base64 32
APP_SECRET="change-me-to-a-long-random-string"

# Public base URL of the app (used for Stripe redirect URLs)
APP_URL="http://localhost:3000"

# Public base URL used for SEO (canonical tags, sitemap, OG, password-reset links).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (free tiers) — optional locally; see DEPLOY.md
# ─────────────────────────────────────────────────────────────────────────────
# Postgres (Neon free tier). To use it: set DATABASE_URL above to the Neon URL
# AND change provider in prisma/schema.prisma from "sqlite" to "postgresql".
#
# Email delivery (Resend free tier). Empty = password-reset links are logged to
# the server console instead of emailed (fine for dev).
RESEND_API_KEY=""
EMAIL_FROM="TireTrader <onboarding@resend.dev>"
#
# Persistent uploads (Vercel Blob, free on Hobby). Empty = local /public/uploads
# (ephemeral on serverless). When set, also run:  npm i @vercel/blob
BLOB_READ_WRITE_TOKEN=""

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE  —  PASTE YOUR OWN TEST-MODE KEYS HERE
# ─────────────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com (toggle "Test mode" ON, top-right).
#
#  1. STRIPE_SECRET_KEY      -> Developers ▸ API keys ▸ "Secret key"      (sk_test_...)
#  2. STRIPE_PUBLISHABLE_KEY -> Developers ▸ API keys ▸ "Publishable key" (pk_test_...)
#  3. STRIPE_PRICE_ID        -> Product catalog ▸ create a $10/month recurring price,
#                               then copy its Price ID                    (price_...)
#  4. STRIPE_WEBHOOK_SECRET  -> Run the Stripe CLI locally:
#                                 stripe listen --forward-to localhost:3000/api/stripe/webhook
#                               It prints a signing secret                (whsec_...)
#
# Leave these as the placeholders below to run the app WITHOUT real Stripe — the
# app falls back to a built-in "dev mode" that simulates a successful checkout so
# you can test the subscription gate end-to-end. Paste real keys to use Stripe.
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
STRIPE_PRICE_ID="price_REPLACE_ME"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"
