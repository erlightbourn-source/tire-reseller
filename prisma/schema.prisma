generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String
  location           String?
  createdAt          DateTime @default(now())

  // Account type. Buyers browse free; sellers can list tires.
  role               String   @default("buyer") // buyer | seller

  // Seller billing. The first year of selling is free for every seller;
  // sellerFreeUntil is when that free promo ends (after which $10/mo applies).
  sellerFreeUntil        DateTime?
  stripeCustomerId       String?
  subscriptionStatus     String   @default("inactive") // inactive | active | canceled | past_due
  subscriptionPriceId    String?
  subscriptionCurrentEnd DateTime?

  listings  Listing[]
  buyerThreads  Thread[]  @relation("BuyerThreads")
  sellerThreads Thread[]  @relation("SellerThreads")
  messages  Message[]
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  brand       String
  size        String   // e.g. 225/45R17
  quantity    Int      @default(1)
  condition   String   // new | used
  treadDepth  String?  // e.g. "9/32in" or "new"
  priceCents  Int
  location    String
  description String?
  status      String   @default("active") // active | sold
  views       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  photos   Photo[]
  threads  Thread[]

  @@index([sellerId])
  @@index([brand])
  @@index([size])
  @@index([condition])
  @@index([status])
}

model Photo {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  sort      Int     @default(0)

  @@index([listingId])
}

model Thread {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation("BuyerThreads", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    User     @relation("SellerThreads", fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  readAt    DateTime?

  @@index([threadId])
}
