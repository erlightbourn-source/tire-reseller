generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String
  location           String?
  state              String?  // 2-letter home state — used to pre-load local listings
  createdAt          DateTime @default(now())

  // Account type. Buyers browse free; sellers can list tires.
  role               String   @default("buyer") // buyer | seller
  pro                Boolean  @default(false)   // Pro seller upgrade
  admin              Boolean  @default(false)   // platform moderator

  // Denormalized seller rating (maintained on review write + backfilled) so the
  // browse min-rating filter is a DB clause, not an in-JS pass.
  ratingAvg          Float    @default(0)
  ratingCount        Int      @default(0)

  // Session invalidation: bumping this revokes all existing JWTs (logout-all,
  // password change/reset). Password-reset token is stored hashed with expiry.
  tokenVersion       Int      @default(0)
  resetTokenHash     String?
  resetTokenExpiry   DateTime?
  deletedAt          DateTime? // soft-delete: account scheduled for removal (7-day grace)

  // Seller billing. The first year of selling is free for every seller;
  // sellerFreeUntil is when that free promo ends (after which $10/mo applies).
  sellerFreeUntil        DateTime?
  stripeCustomerId       String?
  subscriptionStatus     String   @default("inactive") // inactive | active | canceled | past_due
  subscriptionPriceId    String?
  subscriptionCurrentEnd DateTime?

  listings  Listing[]
  buyerThreads  Thread[]  @relation("BuyerThreads")
  sellerThreads Thread[]  @relation("SellerThreads")
  messages  Message[]
  favorites Favorite[]
  savedSearches   SavedSearch[]
  reviewsReceived Review[] @relation("ReviewsReceived")
  reviewsWritten  Review[] @relation("ReviewsWritten")
  reports         Report[]
  blocksMade      Block[]  @relation("Blocker")
  blocksReceived  Block[]  @relation("Blocked")
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  brand       String
  size        String   // e.g. 225/45R17
  quantity    Int      @default(1)
  condition   String   // new | used
  treadDepth  String?  // e.g. "9/32in" or "new"
  priceCents  Int
  location    String
  state       String?  // 2-letter US state code derived from location
  lat         Float?   // geocoded from city for radius search
  lng         Float?
  description String?
  status      String   @default("active") // active | sold

  // Tire-specific attributes (the marketplace's differentiator vs generic listings)
  season      String?  // summer | winter | all-season | all-weather
  loadIndex   String?  // e.g. "91"
  speedRating String?  // e.g. "Y"
  runFlat     Boolean  @default(false)
  shipping    Boolean  @default(false) // seller offers shipping (vs local pickup only)
  dotYear     Int?     // manufacture (DOT) year, e.g. 2022

  featured    Boolean  @default(false) // promoted listing
  hidden      Boolean  @default(false) // auto-hidden after enough reports
  views       Int      @default(0)

  // Denormalized columns for indexed filtering/sorting (populated on write +
  // backfilled). Avoids `LIKE '%size%'` scans, in-JS tread filtering, the
  // per-request price-cohort scan, and enables DB-side ordering by seller-pro.
  widthMm      Int?     // 245 from 245/40R19
  aspectRatio  Int?     // 40
  rimDiameter  Int?     // 19
  treadDepth32 Float?   // parsed 32nds, e.g. 8 or 8.5
  perTireCents Int?     // priceCents / quantity
  sellerPro    Boolean  @default(false) // mirrors seller.pro for ranked placement

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  photos    Photo[]
  threads   Thread[]
  favorites Favorite[]
  viewEvents ListingView[]
  reports    Report[]

  @@index([sellerId])
  @@index([brand])
  @@index([size])
  @@index([condition])
  @@index([status])
  @@index([state])
  @@index([season])
  @@index([featured])
  @@index([createdAt])
  @@index([rimDiameter])
  @@index([treadDepth32])
  @@index([widthMm, aspectRatio, rimDiameter])
  // Hot browse ordering: active, then featured/pro/recency.
  @@index([status, featured, sellerPro, createdAt])
}

model EmailAlert {
  id         String   @id @default(cuid())
  email      String
  query      String   // saved-search querystring
  label      String
  token      String   @unique // one-click unsubscribe
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([email, query])
  @@index([email])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // nullable so logs survive account deletion
  action    String   // login | signup | password_change | password_reset | account_delete | logout_all
  ip        String?
  meta      String?  // optional JSON detail
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Photo {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  sort      Int     @default(0)

  @@index([listingId])
}

model Thread {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation("BuyerThreads", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    User     @relation("SellerThreads", fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  readAt    DateTime?

  // "make an offer" support
  kind        String  @default("text") // text | offer
  offerCents  Int?
  offerStatus String? // pending | accepted | declined

  @@index([threadId])
}

model SavedSearch {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  query      String   // URL querystring of the filters
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  sellerId  String
  seller    User     @relation("ReviewsReceived", fields: [sellerId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("ReviewsWritten", fields: [authorId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  body      String?
  createdAt DateTime @default(now())

  @@unique([sellerId, authorId])
  @@index([sellerId])
}

model ListingView {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([createdAt])
}

model Report {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String
  createdAt  DateTime @default(now())

  @@unique([listingId, reporterId])
  @@index([listingId])
  @@index([reporterId]) // reporter-scoped lookups (rate-limit / credibility join)
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId]) // reverse lookups (the bidirectional block check on message send)
}
